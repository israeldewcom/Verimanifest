{
  "name": "verimanifest-backend",
  "version": "5.1.0",
  "description": "Enterprise Compliance Infrastructure for Regulated Waste Logistics",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --coverage --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "migrate": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "seed": "ts-node src/database/seed.ts",
    "docker:build": "docker build -t verimanifest-api .",
    "docker:run": "docker-compose up -d"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "prisma": "^5.14.0",
    "express": "^4.19.2",
    "socket.io": "^4.7.5",
    "socket.io-redis": "^6.1.1",
    "bullmq": "^5.7.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "zod": "^3.23.8",
    "@aws-sdk/client-s3": "^3.577.0",
    "@aws-sdk/s3-request-presigner": "^3.577.0",
    "@aws-sdk/lib-storage": "^3.577.0",
    "pdfkit": "^0.15.0",
    "qr-image": "^3.2.0",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.3.0",
    "rate-limit-redis": "^4.2.0",
    "winston": "^3.13.0",
    "node-schedule": "^2.1.1",
    "stripe": "^15.7.0",
    "nodemailer": "^6.9.13",
    "twilio": "^5.1.0",
    "prom-client": "^15.1.3",
    "response-time": "^2.3.2",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.4",
    "uuid": "^9.0.1",
    "date-fns": "^3.6.0",
    "compression": "^1.7.4",
    "axios": "^1.7.2",
    "node-cron": "^3.0.3",
    "validator": "^13.12.0",
    "handlebars": "^4.7.8",
    "archiver": "^7.0.1",
    "csv-parser": "^3.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@types/jest": "^29.5.12",
    "@types/uuid": "^9.0.8",
    "@types/multer": "^1.4.11",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/nodemailer": "^6.4.14",
    "@types/pdfkit": "^0.13.4",
    "@types/qr-image": "^3.2.8",
    "@types/sharp": "^0.32.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/validator": "^13.11.10",
    "@types/archiver": "^6.0.2",
    "typescript": "^5.4.5",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "prettier": "^3.3.2"
  }
