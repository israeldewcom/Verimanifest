NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://verimanifest:verimanifest@localhost:5432/verimanifest
DATABASE_READ_URL=postgresql://verimanifest:verimanifest@localhost:5432/verimanifest

# Redis
REDIS_URL=redis://localhost:6379
REDIS_CLUSTER_URLS=

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY=your-access-key
AWS_SECRET_KEY=your-secret-key
S3_BUCKET=verimanifest-documents
CLOUDFRONT_DOMAIN=

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# SMS
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PROFESSIONAL_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# Paystack
PAYSTACK_SECRET_KEY=sk_test_...

# Blockchain (optional)
ETHEREUM_RPC_URL=
ETHEREUM_PRIVATE_KEY=
MANIFEST_VERIFICATION_CONTRACT=
HYPERLEDGER_CONNECTION_PROFILE=

# AI/ML
TENSORFLOW_MODEL_PATH=
WASTE_CLASSIFICATION_API=https://api.openai.com/v1/chat/completions
OPENAI_API_KEY=sk-...

# Taxes
AVALARA_ACCOUNT_ID=
AVALARA_LICENSE_KEY=
TAXJAR_API_KEY=

# Feature Flags
LAUNCHDARKLY_SDK_KEY=
UNLEASH_API_URL=

# Secrets Management
VAULT_ADDR=
VAULT_TOKEN=

# Monitoring
SENTRY_DSN=
NEW_RELIC_LICENSE_KEY=
DD_API_KEY=
OTEL_EXPORTER_OTLP_ENDPOINT=

# Rate Limiting - per plan overrides
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_FREE=50
RATE_LIMIT_MAX_STARTER=200
RATE_LIMIT_MAX_PROFESSIONAL=1000
RATE_LIMIT_MAX_ENTERPRISE=5000

# WebSocket
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_CONNECTIONS=10000

# Cache TTLs
CACHE_TTL=3600
SESSION_CACHE_TTL=1800
LOCATION_CACHE_TTL=300

# Geocoding
GEOCODER_PROVIDER=google   # google or mapbox
GOOGLE_MAPS_API_KEY=
MAPBOX_ACCESS_TOKEN=

# Data Warehouse
WAREHOUSE_TYPE=bigquery   # bigquery or snowflake
BIGQUERY_PROJECT_ID=
BIGQUERY_DATASET=verimanifest
BIGQUERY_CLIENT_EMAIL=
BIGQUERY_PRIVATE_KEY=
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=VERIMANIFEST
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=

# Marketplace
MARKETPLACE_PLATFORM_FEE_PERCENT=5

# White Label
WHITE_LABEL_DEFAULT_LOGO_URL=
WHITE_LABEL_DEFAULT_PRIMARY_COLOR=#2D3748

# Usage Billing
USAGE_PRICE_ID_MANIFEST=price_...   # Stripe usage-based price per manifest

# Frontend URL (for reset links, invites)
APP_URL=http://localhost:3001
